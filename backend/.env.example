## SocietyPro Backend — Home Server Configuration
## Copy this to .env and fill in real values (never commit .env)

# ── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...   # Project Settings → API → service_role
SUPABASE_JWT_SECRET=your-jwt-secret    # Project Settings → API → JWT Secret

# ── Twilio SendGrid (Email) ───────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM=noreply@societypro.in
SENDGRID_FROM_NAME=SocietyPro

# ── MSG91 (SMS — India) ───────────────────────────────────────────
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxxxx
MSG91_SENDER_ID=SCTYPR
MSG91_TEMPLATE_ID=your_dlt_approved_template_id

# ── Security ──────────────────────────────────────────────────────
# Random 64-char string — generate with: openssl rand -hex 32
INTERNAL_TOKEN=generate_with_openssl_rand_hex_32

# ── Server ───────────────────────────────────────────────────────
# GitHub Pages URL (to restrict CORS)
CORS_ORIGIN=https://YOUR_USERNAME.github.io
PORT=3001
NODE_ENV=production

# ── Home Server Notes ─────────────────────────────────────────────
# For HTTPS on your home server (required for GitHub Pages → home server):
# Option A: Cloudflare Tunnel (free, no port-forwarding needed)
#   cloudflared tunnel --url http://localhost:3001
# Option B: Nginx + Let's Encrypt on your home server
#   certbot --nginx -d home.yourdomain.com
# Option C: ngrok (for testing only)
#   ngrok http 3001
